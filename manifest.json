{
  "manifest_version": 2,
  "name": "SocSci/Econ Preprint Recognizer",
  "version": "0.1.0",
  "description": "Recognize NBER and SSRN preprint PDFs and create Zotero preprint items.",
  "author": "Zhicheng",
  "homepage_url": "https://github.com/Si1entPe661e/zotero-socsci-econ-preprint-recognizer",
  "icons": {
    "48": "assets/icon.svg",
    "96": "assets/icon.svg"
  },
  "applications": {
    "zotero": {
      "id": "zotero-socsci-econ-preprint-recognizer@si1entpe661e.github.io",
      "strict_min_version": "7.0",
      "strict_max_version": "10.0.*",
      "update_url": "https://raw.githubusercontent.com/Si1entPe661e/zotero-socsci-econ-preprint-recognizer/main/updates.json"
    }
  }
}

{
  "manifest_version": 2,
  "name": "SocSci/Econ Preprint Recognizer",
  "version": "0.1.0",
  "description": "Recognize NBER and SSRN preprint PDFs and create Zotero preprint items.",
  "author": "Zhicheng",
  "homepage_url": "https://www.ssrn.com/",
  "icons": {
    "48": "assets/icon.svg",
    "96": "assets/icon.svg"
  },
  "applications": {
    "zotero": {
      "id": "nber-zotero-plugin@example.com",
      "strict_min_version": "7.0",
      "strict_max_version": "10.0.*",
      "update_url": "https://example.com/nber-zotero-plugin/updates.json"
    }
  }
}
